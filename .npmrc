# Configurações para garantir deploy automático sem erros
strict-peer-dependencies=false
auto-install-peers=true
confirm-scripts=false
ignore-scripts=false

# Permitir builds de dependências críticas
allowed-builds=@google/genai,@tailwindcss/oxide,esbuild,ffmpeg-static,protobufjs,sharp,bcryptjs

# Patches e Overrides (v11+ lê daqui ou do workspace)
patched-dependencies=wouter@3.7.1:patches/wouter@3.7.1.patch
overrides.tailwindcss>nanoid=3.3.7
