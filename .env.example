# ============================================================================
# MINE Rede Social - Environment Variables
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=production
APP_PORT=3000
LOG_LEVEL=info

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=mysql://mine:mine123@localhost:3306/mine_social
DB_ROOT_PASSWORD=root
DB_NAME=mine_social
DB_USER=mine
DB_PASSWORD=mine123
DB_PORT=3306

# ============================================================================
# REDIS CACHE
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=seu-secret-jwt-muito-seguro-aqui-mude-em-producao
SESSION_SECRET=seu-session-secret-aqui

# ============================================================================
# MANUS OAUTH
# ============================================================================
VITE_APP_ID=seu-app-id-manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=seu-open-id-manus
OWNER_NAME=Seu Nome

# ============================================================================
# MANUS BUILT-IN APIs
# ============================================================================
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua-api-key-manus-backend
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=sua-api-key-manus-frontend

# ============================================================================
# APPLICATION BRANDING
# ============================================================================
VITE_APP_TITLE=MINE Rede Social
VITE_APP_LOGO=https://seu-logo-url.jpg

# ============================================================================
# FRONTEND URL (para CORS)
# ============================================================================
FRONTEND_URL=http://localhost:5173

# ============================================================================
# AWS S3 (para upload de mídia)
# ============================================================================
# Nota: Credenciais S3 são injetadas automaticamente pelo Manus
# Não é necessário configurar manualmente

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FILE UPLOAD LIMITS
# ============================================================================
MAX_IMAGE_SIZE=5242880
MAX_VIDEO_SIZE=52428800

# ============================================================================
# LOGGING
# ============================================================================
SENTRY_DSN=

# ============================================================================
# ANALYTICS
# ============================================================================
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. NUNCA commite o arquivo .env para o Git
# 2. Em produção, use variáveis de ambiente seguras
# 3. Mude JWT_SECRET e SESSION_SECRET em produção
# 4. Configure DATABASE_URL com credenciais seguras
# 5. Use HTTPS em produção
# 6. Habilite CORS apenas para domínios confiáveis
